
-- 用户角色枚举
CREATE TYPE user_role AS ENUM ('teacher', 'boss', 'parent');

-- 用户资料表
CREATE TABLE profiles (
  id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
  email TEXT NOT NULL,
  full_name TEXT NOT NULL,
  role user_role NOT NULL,
  phone TEXT,
  avatar_url TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;

-- 学生表
CREATE TABLE students (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name TEXT NOT NULL,
  parent_id UUID REFERENCES profiles(id) ON DELETE SET NULL,
  total_hours INTEGER DEFAULT 0,
  remaining_hours DECIMAL(5,1) DEFAULT 0,
  alert_threshold INTEGER DEFAULT 2,
  status TEXT DEFAULT 'active' CHECK (status IN ('active', 'inactive')),
  notes TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE students ENABLE ROW LEVEL SECURITY;

-- 课时记录表
CREATE TABLE class_records (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id UUID NOT NULL REFERENCES students(id) ON DELETE CASCADE,
  teacher_id UUID NOT NULL REFERENCES profiles(id),
  class_date TIMESTAMPTZ NOT NULL,
  hours_consumed DECIMAL(3,1) NOT NULL DEFAULT 1.0,
  photo_url TEXT,
  notes TEXT,
  status TEXT DEFAULT 'confirmed' CHECK (status IN ('pending', 'confirmed', 'disputed')),
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE class_records ENABLE ROW LEVEL SECURITY;

-- 预警记录表
CREATE TABLE alert_logs (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id UUID NOT NULL REFERENCES students(id) ON DELETE CASCADE,
  alert_type TEXT NOT NULL CHECK (alert_type IN ('low_hours', 'renewal_reminder')),
  remaining_hours DECIMAL(5,1) NOT NULL,
  sent_to UUID[] NOT NULL,
  sent_at TIMESTAMPTZ DEFAULT NOW(),
  is_read BOOLEAN DEFAULT false
);

ALTER TABLE alert_logs ENABLE ROW LEVEL SECURITY;

-- 创建profiles时自动设置时间戳的触发器
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_profiles_updated_at BEFORE UPDATE ON profiles
  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_students_updated_at BEFORE UPDATE ON students
  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_class_records_updated_at BEFORE UPDATE ON class_records
  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

-- 新用户注册时自动创建profile
CREATE OR REPLACE FUNCTION handle_new_user()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO profiles (id, email, full_name, role)
  VALUES (
    NEW.id,
    NEW.email,
    COALESCE(NEW.raw_user_meta_data->>'full_name', NEW.email),
    COALESCE((NEW.raw_user_meta_data->>'role')::user_role, 'parent'::user_role)
  );
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION handle_new_user();

-- 课时记录创建后自动更新学生剩余课时
CREATE OR REPLACE FUNCTION update_student_hours()
RETURNS TRIGGER AS $$
BEGIN
  IF TG_OP = 'INSERT' THEN
    UPDATE students
    SET remaining_hours = remaining_hours - NEW.hours_consumed
    WHERE id = NEW.student_id;
  ELSIF TG_OP = 'DELETE' THEN
    UPDATE students
    SET remaining_hours = remaining_hours + OLD.hours_consumed
    WHERE id = OLD.student_id;
  ELSIF TG_OP = 'UPDATE' THEN
    UPDATE students
    SET remaining_hours = remaining_hours + OLD.hours_consumed - NEW.hours_consumed
    WHERE id = NEW.student_id;
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER on_class_record_change
  AFTER INSERT OR UPDATE OR DELETE ON class_records
  FOR EACH ROW EXECUTE FUNCTION update_student_hours();

-- RLS 策略

-- Profiles: 用户可以查看自己的资料，老板和教师可以查看所有人
CREATE POLICY "用户可以查看自己的资料"
  ON profiles FOR SELECT
  USING (auth.uid() = id);

CREATE POLICY "老板和教师可以查看所有资料"
  ON profiles FOR SELECT
  USING (
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role IN ('boss', 'teacher')
    )
  );

CREATE POLICY "用户可以更新自己的资料"
  ON profiles FOR UPDATE
  USING (auth.uid() = id);

-- Students: 家长只能看自己的孩子，教师和老板可以看所有学生
CREATE POLICY "家长可以查看自己的孩子"
  ON students FOR SELECT
  USING (
    parent_id = auth.uid() OR
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role IN ('boss', 'teacher')
    )
  );

CREATE POLICY "老板和教师可以管理学生"
  ON students FOR ALL
  USING (
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role IN ('boss', 'teacher')
    )
  );

-- Class Records: 家长可以看自己孩子的记录，教师可以看自己教的，老板可以看所有
CREATE POLICY "查看课时记录"
  ON class_records FOR SELECT
  USING (
    teacher_id = auth.uid() OR
    EXISTS (
      SELECT 1 FROM students s
      WHERE s.id = student_id AND s.parent_id = auth.uid()
    ) OR
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role = 'boss'
    )
  );

CREATE POLICY "教师可以创建课时记录"
  ON class_records FOR INSERT
  WITH CHECK (
    teacher_id = auth.uid() AND
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role IN ('teacher', 'boss')
    )
  );

CREATE POLICY "教师可以更新自己的记录"
  ON class_records FOR UPDATE
  USING (
    teacher_id = auth.uid() OR
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role = 'boss'
    )
  );

CREATE POLICY "老板可以删除记录"
  ON class_records FOR DELETE
  USING (
    EXISTS (
      SELECT 1 FROM profiles
      WHERE id = auth.uid() AND role = 'boss'
    )
  );

-- Alert Logs: 相关人员可以查看
CREATE POLICY "查看预警记录"
  ON alert_logs FOR SELECT
  USING (
    auth.uid() = ANY(sent_to) OR
    EXISTS (
      SELECT 1 FROM students s
      WHERE s.id = student_id AND s.parent_id = auth.uid()
    )
  );

CREATE POLICY "系统可以创建预警"
  ON alert_logs FOR INSERT
  WITH CHECK (true);

